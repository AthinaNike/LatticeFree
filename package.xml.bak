<?xml version="1.0" encoding="UTF-8"?>
<package format="1" xmlns="https://wiki.freecad.org/Package_Metadata">
  <name>LatticeFree</name>
  <description>TPMS lattice infill generator (Gyroid, Schwarz P,
    Diamond): shell, fillet, relative density control, density grading,
    FEM mid-surface export. Implicit modelling, no CAD booleans.</description>
  <version>1.1.0</version>
  <date>2026-07-06</date>
  <maintainer email="you@example.com">Veronica Massara</maintainer>
  <license file="LICENSE">LGPL-2.1-or-later</license>
  <url type="repository" branch="main">https://github.com/USER/LatticeFree</url>
  <icon>Resources/icons/freelattice.svg</icon>
  <content>
    <workbench>
      <classname>LatticeFreeWorkbench</classname>
      <name>LatticeFree</name>
      <description>TPMS lattice infill generator</description>
      <icon>Resources/icons/freelattice.svg</icon>
      <subdirectory>./</subdirectory>
    </workbench>
  </content>
  <freecadmin>1.0</freecadmin>
</package>
